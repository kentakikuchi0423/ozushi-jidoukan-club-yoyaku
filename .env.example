# ============================================================
# .env.example — 本番・開発ともに、このファイルを複製して
# .env.local / .env.production.local を作る。実値はコミットしない。
# ============================================================

# ---- Next.js ----
# サイトの公開 URL（メール本文中のリンク生成に使う）
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ---- Supabase ----
# 2025-11 以降に作成されたプロジェクトでは、anon / service_role は
# 発行されず、publishable / secret のみが提供される。
# Supabase Studio > Project Settings > API Keys からコピーする。
#
#   publishable: "sb_publishable_..."（クライアント同梱可・RLS 適用）
#   secret     : "sb_secret_..."（サーバー専用・RLS をバイパスし得る）

NEXT_PUBLIC_SUPABASE_URL=""

# クライアント/サーバー両方で使う。旧 anon key も値として貼り付け可。
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""

# Secret key は **絶対にクライアントに露出させない**。
# 管理系 RPC / バックグラウンド処理でのみ使用し、server-only モジュール
# 経由で参照する。旧 service_role key も値として貼り付け可。
SUPABASE_SECRET_KEY=""

# ---- Supabase CLI (migrations) ----
# `pnpm db:push` が使う DB 接続文字列。Personal Access Token は
# アカウント全権限を持ってしまうため、CLI からは Project 固有の
# Postgres 接続（DB パスワードのみ）を使う。ADR-0013 参照。
#
# Supabase Studio > Project Settings > Database > Connection string の
# URI 形式をコピーし、[YOUR-PASSWORD] をプロジェクト作成時の DB パスワード
# に置き換えて貼る。
#
# **devcontainer / GitHub Actions など IPv4 のみの環境では Session pooler
# (port 5432) を使うこと。Direct connection (db.<ref>.supabase.co) は
# IPv6 専用で到達できない。** Transaction pooler (port 6543) は DDL が
# 動かないため migration には使わない。
#
# 例（Session pooler・東京リージョン）:
#   postgresql://postgres.<ref>:<DB_PASSWORD>@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres
#   └── user 名は "postgres" ではなく "postgres.<ref>" になる点に注意
SUPABASE_DB_URL=""

# ---- Resend (メール送信) ----
# Phase 3 で導入。開発中は送信元を検証済みドメインに差し替える。
RESEND_API_KEY=""
# 送信元アドレス（例: "大洲市児童館予約 <no-reply@example.jp>"）
RESEND_FROM_ADDRESS=""

# ---- Admin 権限管理 ----
# 初期 super_admin 作成用のシード値（初回 seed 時のみ使用）。
# seed 後は必ず削除し、DB 上のアカウントで運用する。
ADMIN_BOOTSTRAP_EMAIL=""
ADMIN_BOOTSTRAP_PASSWORD=""

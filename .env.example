# ============================================================
# .env.example — 本番・開発ともに、このファイルを複製して
# .env.local / .env.production.local を作る。実値はコミットしない。
# ============================================================

# ---- Next.js ----
# サイトの公開 URL（メール本文中のリンク生成に使う）
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ---- Supabase ----
# Supabase プロジェクトの URL と anon key はクライアント/サーバー両方で使う
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Service Role key は **絶対にクライアントに露出させない**。
# 管理系 RPC / バックグラウンド処理でのみ使用し、server-only モジュール経由で参照する。
SUPABASE_SERVICE_ROLE_KEY=""

# ---- Resend (メール送信) ----
# Phase 3 で導入。開発中は送信元を検証済みドメインに差し替える。
RESEND_API_KEY=""
# 送信元アドレス（例: "大洲市児童館予約 <no-reply@example.jp>"）
RESEND_FROM_ADDRESS=""

# ---- Admin 権限管理 ----
# 初期 super_admin 作成用のシード値（初回 seed 時のみ使用）。
# seed 後は必ず削除し、DB 上のアカウントで運用する。
ADMIN_BOOTSTRAP_EMAIL=""
ADMIN_BOOTSTRAP_PASSWORD=""

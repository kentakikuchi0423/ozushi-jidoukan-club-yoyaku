# ============================================================
# .env.example — 本番・開発ともに、このファイルを複製して
# .env.local / .env.production.local を作る。実値はコミットしない。
# ============================================================
#
# 必須項目（必須）/ 任意項目（任意）を各行末に明記しています。
# それぞれの値をどこから取得するかは docs/operations.md §1〜§9 を参照。

# ---- Next.js（必須） ----
# サイトの公開 URL。メール本文中の予約確認 URL の先頭に使う。
# 例: 本番 "https://yoyaku.example.jp" / dev "http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ---- Supabase（必須 3 点） ----
# Supabase Studio > Project Settings > API Keys からコピーする。
# 2025-11 以降のプロジェクトは publishable / secret のみ提供（旧 anon / service_role は発行されない）。
#
#   publishable: "sb_publishable_..."（クライアント同梱可・RLS 適用）
#   secret     : "sb_secret_..."（サーバー専用・RLS をバイパスし得る）

NEXT_PUBLIC_SUPABASE_URL=""

# クライアント / サーバーの両方で使う（publishable もしくは旧 anon）。
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""

# Secret key は **絶対にクライアントに露出させない**。
# 管理系 RPC / バックグラウンド処理でのみ使用し、server-only モジュール経由で参照。
SUPABASE_SECRET_KEY=""

# ---- Supabase CLI（migration 適用用、必須） ----
# `pnpm db:push` が使う DB 接続文字列。
#
# Supabase Studio > Project Settings > Database > Connection string の
# URI 形式をコピーし、[YOUR-PASSWORD] をプロジェクト作成時の DB パスワード
# に置き換えて貼る。
#
# **devcontainer / GitHub Actions など IPv4 のみの環境では Session pooler
# (port 5432) を使うこと。Direct connection (db.<ref>.supabase.co) は
# IPv6 専用で到達できない。** Transaction pooler (port 6543) は DDL が
# 動かないため migration には使わない（ADR-0013）。
#
# 例（Session pooler・東京リージョン）:
#   postgresql://postgres.<ref>:<DB_PASSWORD>@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres
#   └── user 名は "postgres" ではなく "postgres.<ref>" になる点に注意
SUPABASE_DB_URL=""

# ---- Resend（任意、メール送信を実際に行う場合） ----
# 未設定でもアプリは起動するが、予約確定・キャンセル・繰り上げ・招待の
# メールが送信されない。本番では必ず設定し、送信元ドメインを Resend で
# 検証（SPF / DKIM / DMARC）しておく（docs/operations.md §6, §9-7）。
RESEND_API_KEY=""
# 送信元アドレス（例: "大洲市児童館予約 <no-reply@example.jp>"）
RESEND_FROM_ADDRESS=""

# ---- E2E テスト用（任意、Playwright で opt-in フローを回す場合） ----
# 既存の super_admin のログイン情報。アプリ本体では参照されない。
# e2e/admin-flow.spec.ts（RUN_ADMIN_FLOW_E2E=1）で使う。
ADMIN_BOOTSTRAP_EMAIL=""
ADMIN_BOOTSTRAP_PASSWORD=""

# 1 館のみ権限を持つ admin。権限越権 E2E で使う。
# e2e/permission-guard.spec.ts（RUN_PERMISSION_E2E=1）で使う。
ADMIN_SINGLE_FACILITY_EMAIL=""
ADMIN_SINGLE_FACILITY_PASSWORD=""

# 待ちリスト E2E で使う定員 1 のクラブ id（UUID）。
# e2e/reservation-flow.spec.ts（RUN_WAITLIST_E2E=1）で使う。
E2E_WAITLIST_CLUB_ID=""

# ---- Vercel Cron（任意、retention cleanup を有効化する場合） ----
# `/api/cron/retention-cleanup` を守る共有シークレット。
# Vercel は自動的に `Authorization: Bearer <CRON_SECRET>` を付けて GET する。
# 空のまま置くとエンドポイントが 503 を返し、無効化される（ローカル・dev で安全）。
# 本番では 32 バイト以上のランダム文字列を推奨。
CRON_SECRET=""

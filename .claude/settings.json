{
  "$schema": "https://raw.githubusercontent.com/anthropics/claude-code/main/schemas/settings.json",
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git restore:*)",
      "Bash(git switch:*)",
      "Bash(git stash:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(pnpm install)",
      "Bash(pnpm add:*)",
      "Bash(pnpm remove:*)",
      "Bash(pnpm dlx:*)",
      "Bash(pnpm run:*)",
      "Bash(pnpm dev)",
      "Bash(pnpm build)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm typecheck)",
      "Bash(pnpm test:*)",
      "Bash(pnpm exec:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(pwd)",
      "Bash(mkdir:*)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf ~)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git commit --amend:*)",
      "Bash(git rebase:*)",
      "Bash(git filter-branch:*)",
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.*.local)",
      "Read(**/.env)",
      "Read(**/.env.local)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git remote:*)",
      "Bash(gh:*)",
      "Bash(pnpm publish:*)",
      "Bash(npm publish:*)",
      "Bash(supabase:*)",
      "Bash(vercel:*)",
      "Bash(pnpm dlx create-next-app:*)",
      "Write(.env*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '--- STATUS.md (top) ---' && head -40 STATUS.md 2>/dev/null || echo '(no STATUS.md yet)'; echo; echo '--- TASKS.md (summary) ---' && sed -n '1,30p' TASKS.md 2>/dev/null || echo '(no TASKS.md yet)'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[reminder] コード/docs 変更後は TASKS.md と STATUS.md の更新漏れがないか確認してください。'"
          }
        ]
      }
    ]
  }
}
